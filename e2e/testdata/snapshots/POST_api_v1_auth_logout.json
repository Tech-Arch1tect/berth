{
  "method": "POST",
  "path": "/api/v1/auth/logout",
  "status_code": 200,
  "headers": {
    "Content-Type": "application/json"
  },
  "body": {
    "data": {
      "message": "Logout successful. Tokens have been revoked.",
      "revoked_tokens": [
        "access_token",
        "refresh_token"
      ]
    },
    "success": true
  }
}
