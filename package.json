{
  "name": "berth",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"{resources,frontend-e2e}/**/*.{js,ts,tsx,jsx}\"",
    "format:check": "prettier --check \"{resources,frontend-e2e}/**/*.{js,ts,tsx,jsx}\"",
    "lint": "eslint resources/ frontend-e2e/",
    "lint:fix": "eslint resources/ frontend-e2e/ --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "api:generate": "go build -o berth-tmp && ./berth-tmp openapi > openapi.json && orval && rm berth-tmp",
    "api:generate-only": "orval",
    "test:e2e": "playwright test --config frontend-e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config frontend-e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config frontend-e2e/playwright.config.ts --headed"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.169.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "date-fns": "^4.1.0",
    "monaco-editor": "^0.55.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "orval": "^8.6.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.1.5"
  }
}
